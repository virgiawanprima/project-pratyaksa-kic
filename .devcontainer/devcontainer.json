{
	"name": "Python 3 Dev Container",
	"image": "mcr.microsoft.com/devcontainers/python:3-3.11-bookworm",
	"workspaceFolder": "/workspace",
	"postCreateCommand": "pip3 install -r requirements-dev.txt",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance"
			]
		}
	}
}
